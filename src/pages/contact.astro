---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import ContactForm from '../components/ContactForm';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact Ollie Pinto | Portfolio"
  description="Contact Ollie Pinto about work, ideas, or a useful conversation."
  canonicalUrl="https://www.olliepinto.com/contact"
>
  <Navbar client:load />

  <section class="w-full min-h-[80vh] px-6 pt-36 pb-20">
    <div class="mx-auto grid w-full max-w-[1080px] grid-cols-1 gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent-secondary">
          Contact
        </p>
        <h1 class="text-5xl font-serif font-normal text-text-primary md:text-7xl">
          Let's chat.
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-text-muted">
          Send a note about work, ideas, or a useful conversation. I read every
          message and will get back to you as soon as I can.
        </p>
      </div>

      <div class="rounded-3xl border border-border-color bg-surface p-6 shadow-sm md:p-8">
        <ContactForm client:load idPrefix="contact-page" submitLabel="Send Message" />
      </div>
    </div>
  </section>

  <Footer />
</Layout>
